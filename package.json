{
  "name": "whtsnyr-me-server",
  "version": "1.0.0",
  "private": false,
  "description": "Enterprise-ready visitor copilot API with curated local discovery and guarded Swiggy MCP integration.",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "whtsnyr.me",
    "whtsnyr.me server"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/satyamsovan123/whtsnyr-me-server.git"
  },
  "scripts": {
    "development": "nodemon src/server.js",
    "start": "node src/server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --exclude test/integration/**",
    "test:watch": "vitest",
    "test:integration": "vitest run test/integration",
    "test:coverage": "vitest run --coverage",
    "seed": "node scripts/seed.js",
    "verify": "npm run lint && npm run format:check && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.0",
    "bcryptjs": "^3.0.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.18.0",
    "pino": "^9.9.4",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "eslint": "^9.35.0",
    "globals": "^16.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.6.2",
    "vitest": "^3.2.4"
  }
}
