# Keep your existing MongoDB URI exactly as supplied.
MONGO_URI=mongodb://127.0.0.1:27017/whtsnyr
NODE_ENV=development
PORT=3000

# Angular origins, comma separated. Exact origins only.
CORS_ORIGINS=http://localhost:4200
FRONTEND_URL=http://localhost:4200
TRUST_PROXY=0
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log

# Required in production. Development derives a local-only key when omitted.
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
# 32 random bytes encoded as base64: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=
TOKEN_ENCRYPTION_KEY_VERSION=v1

ACCESS_TOKEN_TTL=15m

# Public API base URL. All backend routes are mounted below /api/v1.
API_BASE_URL=https://whtsnyr-me-server.onrender.com/api/v1

# Swiggy delegated OAuth / MCP. Production access is invite-based.
SWIGGY_BASE_URL=https://mcp.swiggy.com
SWIGGY_MCP_BASE_URL=https://mcp.swiggy.com
SWIGGY_OAUTH_REDIRECT_URI=https://whtsnyr-me-server.onrender.com/api/v1/oauth/swiggy/callback
SWIGGY_CLIENT_ID=
# Local development can use RFC 7591 DCR. Prefer a verified client id in production.
SWIGGY_DYNAMIC_CLIENT_REGISTRATION_ENABLED=true
SWIGGY_WRITES_ENABLED=false
SWIGGY_REQUEST_TIMEOUT_MS=10000

# Location resolver. Coordinates can always be supplied directly.
GEOCODING_ENABLED=true
GEOCODER_BASE_URL=https://nominatim.openstreetmap.org
GEOCODER_USER_AGENT=whtsnyr-me/1.0 (contact: dev@example.com)

# Preserved for a future verified-data explanation layer; not required by this API.
OPENAI_API_KEY=
